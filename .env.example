# ─────────────────────────────────────────────
#  JYOTISH PLATFORM — Environment Variables
#  Copy this file to .env.local and fill values
# ─────────────────────────────────────────────

# ── MongoDB Atlas ──────────────────────────────
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/jyotish?retryWrites=true&w=majority
MONGODB_DB_NAME=jyotish

# ── NextAuth.js v5 ─────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here
AUTH_URL=http://localhost:3000

# Google OAuth (console.cloud.google.com)
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# ── Upstash Redis ──────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ── Swiss Ephemeris ────────────────────────────
# Path to .se1 data files (relative to project root)
EPHE_PATH=./ephe

# ── Razorpay (India payments) ──────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ── Stripe (global payments) ───────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# ── Email (Resend) ─────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx
FROM_EMAIL=noreply@yourdomain.com

# ── App Config ─────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Jyotish Platform
NEXT_PUBLIC_BASE_URL=https://yourdomain.com